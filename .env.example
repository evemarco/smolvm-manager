SMOLVM_SOCKET=/tmp/smolvm.sock
MANAGER_HOST=0.0.0.0
MANAGER_PORT=3000

# Pylon auth and app DBs live under the same data directory.
# Pylon owns auth/session state; SvelteKit proxies to Pylon.
PYLON_URL=http://127.0.0.1:3001
PYLON_COMMAND=pylon
PYLON_APP_DB=sqlite://./data/pylon-app.db
PYLON_SESSION_DB=sqlite://./data/pylon-sessions.db
PYLON_PID_FILE=./.pylon/pylon.pid

# Set to true in test environments where the Pylon CLI cannot run.
# PYLON_AUTH_MOCK=true

DOCKER_HUB_TOKEN=
