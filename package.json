{
  "name": "smolvm-manager",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000 --strictPort",
    "dev:manager": "bun run scripts/start-manager.ts",
    "dev:pylon": "pylon dev app.ts",
    "build": "vite build",
    "start:manager": "bun run scripts/start-manager.ts --prod",
    "preview": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test src",
    "test:e2e": "playwright test",
    "gate": "bun run scripts/quality-gate.ts",
    "admin:reset": "bun run scripts/reset-admin.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "bun-types": "^1.3.14",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
    "@pylonsync/functions": "0.3.298",
    "@pylonsync/sdk": "0.3.298",
    "@pylonsync/sync": "0.3.298"
  }
}
