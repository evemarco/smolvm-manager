{
  "name": "smolvm-manager",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000 --strictPort",
    "dev:manager": "bun run scripts/start-manager.ts",
    "dev:pylon": "pylon dev app.ts",
    "build": "vite build",
    "start:manager": "bun run scripts/start-manager.ts --prod",
    "preview": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test src",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.7"
  },
  "dependencies": {
    "@lucide/svelte": "^1.17.0",
    "@pylonsync/functions": "^0.3.225",
    "@pylonsync/sdk": "^0.3.225",
    "@pylonsync/sync": "^0.3.225"
  }
}
