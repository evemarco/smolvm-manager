# SmolVM Manager environment file
# Place this at /etc/smolvm-manager/env and reference it from the systemd unit.

SMOLVM_SOCKET=/tmp/smolvm.sock
MANAGER_HOST=127.0.0.1
MANAGER_PORT=3000

# Pylon configuration
PYLON_URL=http://127.0.0.1:3001
PYLON_COMMAND=pylon
PYLON_APP_DB=sqlite:///var/lib/smolvm-manager/data/pylon-app.db
PYLON_SESSION_DB=sqlite:///var/lib/smolvm-manager/data/pylon-sessions.db
PYLON_PID_FILE=/var/lib/smolvm-manager/.pylon/pylon.pid

# Optional Docker Hub token for authenticated image search
# DOCKER_HUB_TOKEN=your_token_here
