# SmolVM Manager environment file
# Place this at /etc/smolvm-manager/env and reference it from the systemd unit.

SMOLVM_SOCKET=/tmp/smolvm.sock
MANAGER_HOST=127.0.0.1
MANAGER_PORT=3000

# Pylon configuration
PYLON_URL=http://127.0.0.1:3001
PYLON_COMMAND=pylon
PYLON_DB_PATH=/var/lib/smolvm-manager/data/pylon-app.db
PYLON_SESSION_DB=/var/lib/smolvm-manager/data/pylon-sessions.db
PYLON_PID_FILE=/var/lib/smolvm-manager/.pylon/pylon.pid

# Pylon store mode: typed (default), rest, or mock
PYLON_STORE_MODE=typed

# Admin bearer token for server-side Pylon API calls. Required with Pylon
# 0.3.333 or later (anonymous entity access is default-denied). The manager
# sends it as Authorization: Bearer and Pylon reads the same value from its
# environment. Generate one with: openssl rand -hex 32
# PYLON_ADMIN_TOKEN=change_me_to_a_long_random_hex

# Server-side secret for background jobs (metrics sampler, audit logging)
# PYLON_SERVICE_TOKEN=generate_a_strong_random_secret_here

# Optional Docker Hub token for authenticated image search
# DOCKER_HUB_TOKEN=your_token_here
